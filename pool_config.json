{
    "_comment": "ManaCoin (MNC) — NOMP Mining Pool Configuration",
    "_docs": "https://github.com/zone117x/node-open-mining-portal",

    "coins": {
        "manacoin": {
            "name": "ManaCoin",
            "symbol": "MNC",
            "algorithm": "scrypt",
            "txMessages": false
        }
    },

    "pool": {
        "coin": "manacoin",
        "enabled": true,
        "stratumHost": "0.0.0.0",

        "ports": {
            "3333": {
                "diff": 0.5,
                "varDiff": {
                    "minDiff": 0.25,
                    "maxDiff": 512,
                    "targetTime": 15,
                    "retargetTime": 90,
                    "variancePercent": 30
                }
            },
            "5555": {
                "diff": 8,
                "varDiff": {
                    "minDiff": 4,
                    "maxDiff": 1024,
                    "targetTime": 15,
                    "retargetTime": 90,
                    "variancePercent": 30
                }
            }
        },

        "daemons": [
            {
                "host": "127.0.0.1",
                "port": 9889,
                "user": "manacoinrpc",
                "password": "CHANGE_THIS_PASSWORD_NOW"
            }
        ],

        "p2p": {
            "enabled": true,
            "host": "127.0.0.1",
            "port": 9888,
            "disableTransactions": true
        },

        "rewardRecipients": {
            "YOUR_POOL_MNC_ADDRESS": 1.0
        },

        "blockRefreshInterval": 1000,
        "jobRebroadcastTimeout": 55,
        "connectionTimeout": 600,

        "emitInvalidBlockHashes": false,
        "validateWorkerUsername": true,
        "tcpProxyProtocol": false,
        "banning": {
            "enabled": true,
            "time": 600,
            "invalidPercent": 50,
            "checkThreshold": 500,
            "purgeInterval": 300
        },

        "redis": {
            "host": "127.0.0.1",
            "port": 6379
        }
    },

    "website": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 8888,
        "stratumHost": "pool.manacoin.org",
        "stats": {
            "updateInterval": 60,
            "historicalRetention": 43200,
            "hashrateWindow": 300
        },
        "adminAccessKey": "CHANGE_THIS_ADMIN_KEY"
    },

    "profitSwitch": {
        "enabled": false
    }
}
